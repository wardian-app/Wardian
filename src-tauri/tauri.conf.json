{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wardian",
  "version": "0.3.5",
  "identifier": "org.wardian.desktop",
  "build": {
    "beforeDevCommand": "npm run vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run stage-cli",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Wardian",
        "width": 800,
        "height": 600,
        "maximized": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": [
      "nsis",
      "app",
      "dmg",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/transparent/32x32.png",
      "icons/transparent/128x128.png",
      "icons/transparent/128x128@2x.png",
      "icons/transparent/icon.icns",
      "icons/transparent/icon.ico"
    ],
    "resources": [
      "agent_prompts/*",
      "../scripts/*",
      "resources/bin/*",
      "resources/library/skills/**/*"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBQUQ3NkRBNzBDMTc3RDkKUldUWmQ4RncybmF0eWtadWFpNURLNUVONDN3UXdPYm9OZE8vbS9ISjJzUWxVTy91U3RzZ1FOcnkK",
      "endpoints": [
        "https://github.com/tangemicioglu/Wardian/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
