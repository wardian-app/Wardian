{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wardian",
  "version": "0.2.1",
  "identifier": "org.wardian.app",
  "build": {
    "beforeDevCommand": "npm run vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Wardian",
        "width": 800,
        "height": 600,
        "maximized": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "deb", "appimage"],
    "icon": [
      "icons/transparent/32x32.png",
      "icons/transparent/128x128.png",
      "icons/transparent/128x128@2x.png",
      "icons/transparent/icon.icns",
      "icons/transparent/icon.ico"
    ],
    "resources": ["agent_prompts/*", "../scripts/*"]
  }
}