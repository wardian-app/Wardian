{
  "name": "wardian",
  "private": true,
  "version": "0.4.4",
  "type": "module",
  "description": "Where local agent work becomes visible, durable, and malleable.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wardian-app/Wardian.git"
  },
  "homepage": "https://wardian.org",
  "bugs": {
    "url": "https://github.com/wardian-app/Wardian/issues"
  },
  "scripts": {
    "start": "tauri dev",
    "dev": "tauri dev",
    "vite": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "stage-cli": "node scripts/stage-cli.mjs",
    "stage-cli:dev": "node scripts/stage-cli.mjs --profile dev",
    "release:apt-repo": "node scripts/package-managers/generate-apt-repo.mjs",
    "release:package-manifests": "node scripts/package-managers/generate-manifests.mjs",
    "lint": "tsc --noEmit",
    "check:frontend-screenshot": "node scripts/verify-frontend-screenshot.mjs",
    "check:workbench-cutover": "node scripts/verify-workbench-cutover.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:check-llms": "node scripts/verify-llms-txt.mjs",
    "docs:preview": "vitepress preview docs",
    "docs:screenshots": "node scripts/capture-doc-screenshots.mjs",
    "docs:demo-gif": "node scripts/capture-readme-demo-real.mjs",
    "docs:demo-gif:real": "node scripts/capture-readme-demo-real.mjs",
    "perf:workbench": "node scripts/measure-workbench-performance.mjs",
    "perf:workbench:check": "node scripts/measure-workbench-performance.mjs --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:rust": "cd src-tauri && cargo llvm-cov --lcov --output-path ../coverage/rust-lcov.info",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:workbench": "playwright test --config e2e/playwright.workbench.config.ts e2e/tests/workbench-command-palette.spec.ts e2e/tests/workbench-navigation.spec.ts e2e/tests/workbench-overview.spec.ts e2e/tests/workbench-recovery.spec.ts e2e/tests/workbench-screenshot.spec.ts",
    "test:e2e:web": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "test:e2e:native": "node scripts/run-native-e2e.mjs",
    "test:e2e:native:fast": "node scripts/run-native-e2e-fast.mjs",
    "test:e2e:native:workbench": "node scripts/run-native-e2e-fast.mjs e2e-native/tests/workbench-persistence-native.test.mjs e2e-native/tests/terminal-presentation-broker-native.test.mjs e2e-native/tests/workbench-runtime-lifecycle-native.test.mjs e2e-native/tests/remote-gateway-native.test.mjs",
    "test:e2e:native:watch": "node scripts/run-native-e2e-watch.mjs",
    "setup:e2e:native": "node scripts/setup-native-e2e.mjs",
    "setup:e2e:native:windows": "npm run setup:e2e:native"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "dockview-react": "7.0.2",
    "graphology": "^0.26.0",
    "konva": "^9.3.22",
    "monaco-editor": "0.55.1",
    "pdfjs-dist": "5.4.624",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-konva": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sigma": "^3.0.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.24",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.12",
    "selenium-webdriver": "^4.34.0",
    "tailwindcss": "^4.3.1",
    "terser": "^5.46.1",
    "typescript": "~5.8.3",
    "vite": "6.4.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "esbuild": "0.28.1",
    "minimatch@10.2.5": {
      "brace-expansion": "5.0.6"
    },
    "vite": "6.4.3",
    "ws": "8.21.0"
  }
}
