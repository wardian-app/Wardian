{
  "name": "wardian",
  "private": true,
  "version": "0.3.9",
  "type": "module",
  "description": "Local command center for multi-agent CLI workflows — see every session, swap skills on the fly, and chain agents into deterministic pipelines.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wardian-app/Wardian.git"
  },
  "homepage": "https://wardian.org",
  "bugs": {
    "url": "https://github.com/wardian-app/Wardian/issues"
  },
  "scripts": {
    "start": "tauri dev",
    "dev": "tauri dev",
    "vite": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "stage-cli": "node scripts/stage-cli.mjs",
    "stage-cli:dev": "node scripts/stage-cli.mjs --profile dev",
    "release:package-manifests": "node scripts/package-managers/generate-manifests.mjs",
    "lint": "tsc --noEmit",
    "check:frontend-screenshot": "node scripts/verify-frontend-screenshot.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:check-llms": "node scripts/verify-llms-txt.mjs",
    "docs:preview": "vitepress preview docs",
    "docs:screenshots": "node scripts/capture-doc-screenshots.mjs",
    "docs:demo-gif": "node scripts/capture-readme-demo.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:rust": "cd src-tauri && cargo llvm-cov --lcov --output-path ../coverage/rust-lcov.info",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:web": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "test:e2e:native": "node --test --test-concurrency=1 e2e-native/tests",
    "test:e2e:native:fast": "node scripts/run-native-e2e-fast.mjs",
    "test:e2e:native:watch": "node scripts/run-native-e2e-watch.mjs",
    "setup:e2e:native": "node scripts/setup-native-e2e.mjs",
    "setup:e2e:native:windows": "npm run setup:e2e:native"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "graphology": "^0.26.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sigma": "^3.0.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.0",
    "@tauri-apps/cli": "2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.24",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.12",
    "selenium-webdriver": "^4.34.0",
    "tailwindcss": "^4.2.0",
    "terser": "^5.46.1",
    "typescript": "~5.8.3",
    "vite": "6.4.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "minimatch@10.2.5": {
      "brace-expansion": "5.0.6"
    },
    "vite": "6.4.2",
    "ws": "8.20.1"
  }
}
